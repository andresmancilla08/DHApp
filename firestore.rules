rules_version = '2';

// DHApp uses a custom username+PIN auth (httpOnly JWT cookie, no Firebase Auth).
// All Firestore access goes through the server-side Firebase Admin SDK, which
// bypasses these rules entirely. Client-side Firestore SDK is never used.
//
// Data model:
//   users/{uid}                      — user profile (username, pinHash)
//   users/{uid}/characters/{charId}  — character sheets
//
// Security posture: deny all client-side reads and writes. This is correct and
// intentional — the Admin SDK on the server handles all data access with full
// trust, enforced by our own session validation (jose JWT, httpOnly cookie).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
